#!/usr/bin/env bash

reset="\033[0m"
cyan="\033[36m"
green="\033[32m"
yellow="\033[33m"
blue="\033[34m"
magenta="\033[35m"
gray="\033[90m"

host="$(hostname 2>/dev/null || scutil --get LocalHostName 2>/dev/null)"
user="$(whoami)"
shell="$SHELL"
term="$TERM"
tty="$(tty 2>/dev/null)"
pwd="$PWD"
os="$(uname -s)"
kernel="$(uname -r)"
arch="$(uname -m)"
uptime="$(uptime | sed 's/.*up //; s/, [0-9]* users.*//')"

echo -e "${cyan}╭─ sysfetch ${reset}"
echo -e "${cyan}│${reset} ${green}user${reset}     : $user"
echo -e "${cyan}│${reset} ${green}host${reset}     : $host"
echo -e "${cyan}│${reset} ${green}os${reset}       : $os ($arch)"
echo -e "${cyan}│${reset} ${green}kernel${reset}   : $kernel"
echo -e "${cyan}│${reset} ${green}uptime${reset}   :$uptime"
echo -e "${cyan}│${reset}"
echo -e "${cyan}│${reset} ${yellow}shell${reset}    : $shell"
echo -e "${cyan}│${reset} ${yellow}term${reset}     : $term"
echo -e "${cyan}│${reset} ${yellow}tty${reset}      : $tty"
echo -e "${cyan}│${reset}"
echo -e "${cyan}│${reset} ${magenta}pwd${reset}      : $pwd"
echo -e "${cyan}╰────────────────────────────────"
echo -e "${gray} $(date)${reset}"
